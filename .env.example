# =================================================================
# mandarin-app-fetch — environment variables
# =================================================================
# Copy to .env and fill in your values.  run.sh sources this file.

# --- Doubao (豆包) LLM service ---
# Required for /v1/chat/completions, /v1/models, and /extract endpoints.
# Get cookie from: login to https://www.doubao.com/chat/, open DevTools,
# send a message, find the "completion" request, copy the Cookie header.

DOUBAO_COOKIE_1="paste-your-full-cookie-string-here"
# DOUBAO_COOKIE_2="optional-second-account-for-rotation"

# Device fingerprint — extract from a real request's URL parameters.
# Open DevTools → Network → find a "completion" request → copy these from the URL.
DOUBAO_DEVICE_ID=
DOUBAO_FP=
DOUBAO_TEA_UUID=
DOUBAO_WEB_ID=

# Optional: API key to protect the /v1/* endpoints (default: no auth)
# DOUBAO_API_KEY=sk-your-key-here

# Optional: model mapping as JSON (default: {"doubao-pro-chat": "7338286299411103781"})
# DOUBAO_MODEL_MAPPING={"doubao-pro-chat":"7338286299411103781","doubao-1.5-pro":"7338286299411103781"}

# Optional: default model name
# DOUBAO_DEFAULT_MODEL=doubao-pro-chat

# Optional: session cache TTL in seconds (default: 3600)
# DOUBAO_SESSION_CACHE_TTL=3600

# --- Rate limits (optional, seconds between requests) ---
# RATE_LIMIT_XHS=10
# RATE_LIMIT_DOUYIN=10
# RATE_LIMIT_EXTRACT_DOUBAO=5
