# =================================================================
# mandarin-app-fetch — environment variables
# =================================================================
# Copy to .env and fill in your values.  run.sh sources this file.

# --- LLM service (Doubao via direct HTTP) ---
# Required for /v1/chat/completions, /v1/models, and /extract endpoints.

# Session IDs — comma-separated sessionid values from doubao.com cookies.
# To get: login to https://www.doubao.com/chat/, open DevTools → Application
# → Cookies → copy the "sessionid" value. Multiple values = load balancing.
LLM_SESSION_IDS="paste-sessionid-1,paste-sessionid-2"

# Device params — extract from a real request's URL parameters.
# Open DevTools → Network → find a "completion" request → copy from URL params.
LLM_DEVICE_ID=
LLM_WEB_ID=

# Optional: API key to protect the /v1/* endpoints (default: no auth)
# LLM_API_KEY=sk-your-key-here

# Optional: model mapping as JSON (default: {"doubao-pro-chat": "7338286299411103781"})
# DOUBAO_MODEL_MAPPING={"doubao-pro-chat":"7338286299411103781","doubao-1.5-pro":"7338286299411103781"}

# Optional: default model name
# DOUBAO_DEFAULT_MODEL=doubao-pro-chat

# --- Legacy env vars (still supported as fallbacks) ---
# DOUBAO_COOKIE_1="full-cookie-string"  # sessionid is extracted from this
# DOUBAO_DEVICE_ID=                      # fallback for LLM_DEVICE_ID
# DOUBAO_WEB_ID=                         # fallback for LLM_WEB_ID

# --- Rate limits (optional, seconds between requests) ---
# RATE_LIMIT_XHS=10
# RATE_LIMIT_DOUYIN=10
# RATE_LIMIT_EXTRACT_DOUBAO=5
